{
  "name": "claude-autosarcfg",
  "version": "1.6.1",
  "private": true,
  "description": "Standalone desktop GUI for AUTOSAR BSW configuration",
  "license": "MIT",
  "author": "claude-AutosarCfg contributors",
  "main": "dist/main/index.js",
  "type": "module",
  "bin": {
    "autosarcfg": "./bin/autosarcfg.mjs"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "pnpm build:renderer && pnpm build:main && pnpm build:preload",
    "build:main": "vite build -c vite.main.config.ts",
    "build:preload": "vite build -c vite.preload.config.ts",
    "build:renderer": "vite build -c vite.renderer.config.ts",
    "start": "electron dist/main/index.js",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "verify": "node scripts/verify.mjs",
    "package": "pnpm build && electron-builder --win",
    "package:dir": "pnpm build && electron-builder --win --dir",
    "smoke:packaged": "node scripts/smoke-packaged.mjs",
    "autosarcfg": "node --experimental-strip-types bin/autosarcfg.mjs"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@dbc-forge/core": "file:..\\dbc-forge\\packages\\core",
    "commander": "^12.0.0",
    "fast-xml-parser": "^4.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.11.2",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.38",
    "prettier": "^3.3.2",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.claude.autosarcfg",
    "productName": "AutosarCfg",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "samples",
        "to": "samples",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AutosarCfg"
    },
    "asar": true
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  }
}
