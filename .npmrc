# Use npmmirror for electron binary downloads (CN network).
# CI runners without this env var will time out on github.com releases.
electron_mirror=https://registry.npmmirror.com/-/binary/electron/
sharp_binary_host=https://registry.npmmirror.com/-/binary/sharp
# Skip pnpm 11+ interactive build-script approval prompt for electron + esbuild.
# See pnpm-workspace.yaml for the allowBuilds whitelist.
strict-peer-dependencies=false
auto-install-peers=true