                                  <SHORT-NAME>ADC_TRIGG_SRC_HW</SHORT-NAME>
                                  <ORIGIN>AUTOSAR_ECUC</ORIGIN>
                                  <DESC>
                                    <L-4 L="EN">Type of source event that starts a group conversion.</L-4>
                                  </DESC>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                                <ECUC-ENUMERATION-LITERAL-DEF>
                                  <SHORT-NAME>ADC_TRIGG_SRC_SW</SHORT-NAME>
                                  <ORIGIN>AUTOSAR_ECUC</ORIGIN>
                                  <DESC>
                                    <L-4 L="EN">Type of source event that starts a group conversion.</L-4>
                                  </DESC>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                              </LITERALS>
                            </ECUC-ENUMERATION-PARAM-DEF>
                            <ECUC-ENUMERATION-PARAM-DEF>
                              <SHORT-NAME>AdcHwTrigSignal</SHORT-NAME>
                              <DESC>
                                <L-4 L="EN">Configures on which edge of the hardware trigger signal the driver should react, i.e. start the conversion (only if supported by the ADC hardware).</L-4>
                              </DESC>
                              <LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
                              <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-POST-BUILD</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <LITERALS>
                                <ECUC-ENUMERATION-LITERAL-DEF>
                                  <SHORT-NAME>ADC_HW_TRIG_BOTH_EDGES</SHORT-NAME>
                                  <ORIGIN>AUTOSAR_ECUC</ORIGIN>
                                  <DESC>
                                    <L-4 L="EN">Configures on which edge of the hardware trigger signal the driver should react, i.e. start the conversion (only if supported by the ADC hardware).</L-4>
                                  </DESC>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                                <ECUC-ENUMERATION-LITERAL-DEF>
                                  <SHORT-NAME>ADC_HW_TRIG_FALLING_EDGE</SHORT-NAME>
                                  <ORIGIN>AUTOSAR_ECUC</ORIGIN>
                                  <DESC>
                                    <L-4 L="EN">Configures on which edge of the hardware trigger signal the driver should react, i.e. start the conversion (only if supported by the ADC hardware).</L-4>
                                  </DESC>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                                <ECUC-ENUMERATION-LITERAL-DEF>
                                  <SHORT-NAME>ADC_HW_TRIG_RISING_EDGE</SHORT-NAME>
                                  <ORIGIN>AUTOSAR_ECUC</ORIGIN>
                                  <DESC>
                                    <L-4 L="EN">Configures on which edge of the hardware trigger signal the driver should react, i.e. start the conversion (only if supported by the ADC hardware).</L-4>
                                  </DESC>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                              </LITERALS>
                            </ECUC-ENUMERATION-PARAM-DEF>
                            <ECUC-ENUMERATION-PARAM-DEF>
                              <SHORT-NAME>AdcStreamingBufferMode</SHORT-NAME>
                              <DESC>
                                <L-4 L="EN">Configure streaming buffer as &quot;linear buffer&quot; (i.e. the ADC Driver stops the conversion as soon as the stream buffer is full) or as &quot;ring buffer&quot; (wraps around if the end of the stream buffer is reached).</L-4>
                              </DESC>
                              <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                              <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-POST-BUILD</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <LITERALS>
                                <ECUC-ENUMERATION-LITERAL-DEF>
                                  <SHORT-NAME>ADC_STREAM_BUFFER_CIRCULAR</SHORT-NAME>
                                  <ORIGIN>AUTOSAR_ECUC</ORIGIN>
                                  <DESC>
                                    <L-4 L="EN">Configure streaming buffer as &quot;linear buffer&quot; (i.e. the ADC Driver stops the conversion as soon as the stream buffer is full) or as &quot;ring buffer&quot; (wraps around if the end of the stream buffer is reached).</L-4>
                                  </DESC>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                                <ECUC-ENUMERATION-LITERAL-DEF>
                                  <SHORT-NAME>ADC_STREAM_BUFFER_LINEAR</SHORT-NAME>
                                  <ORIGIN>AUTOSAR_ECUC</ORIGIN>
                                  <DESC>
                                    <L-4 L="EN">Configure streaming buffer as &quot;linear buffer&quot; (i.e. the ADC Driver stops the conversion as soon as the stream buffer is full) or as &quot;ring buffer&quot; (wraps around if the end of the stream buffer is reached).</L-4>
                                  </DESC>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                              </LITERALS>
                            </ECUC-ENUMERATION-PARAM-DEF>
                            <ECUC-FUNCTION-NAME-DEF>
                              <SHORT-NAME>AdcNotification</SHORT-NAME>
                              <ECUC-FUNCTION-NAME-DEF-VARIANTS>
                                <ECUC-FUNCTION-NAME-DEF-CONDITIONAL>
                                  <DEFAULT-VALUE></DEFAULT-VALUE>
                                </ECUC-FUNCTION-NAME-DEF-CONDITIONAL>
                              </ECUC-FUNCTION-NAME-DEF-VARIANTS>
                              <DESC>
                                <L-4 L="EN">Callback function for each group</L-4>
                              </DESC>
                              <LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
                              <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                            </ECUC-FUNCTION-NAME-DEF>
