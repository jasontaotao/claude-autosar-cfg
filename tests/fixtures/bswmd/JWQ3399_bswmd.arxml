                      <SUB-CONTAINERS>
                        <ECUC-PARAM-CONF-CONTAINER-DEF>
                          <SHORT-NAME>OVUV_Thresholds</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN"></L-2>
                          </DESC>
                          <LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
                          <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                          <MULTIPLICITY-CONFIG-CLASSES>
                            <ECUC-MULTIPLICITY-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-POST-BUILD</CONFIG-VARIANT>
                            </ECUC-MULTIPLICITY-CONFIGURATION-CLASS>
                            <ECUC-MULTIPLICITY-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-MULTIPLICITY-CONFIGURATION-CLASS>
                          </MULTIPLICITY-CONFIG-CLASSES>
                          <PARAMETERS>
                            <ECUC-INTEGER-PARAM-DEF>
                              <SHORT-NAME>OV_ThresholdConfig</SHORT-NAME>
                              <DEFAULT-VALUE>0</DEFAULT-VALUE>
                              <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                              <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-POST-BUILD</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <MAX>165</MAX>
                              <MIN>0</MIN>
                              <DESC>
                                <L-4 L="EN">overvoltage threshold for the overvoltage protection.
0x00 = 2700 mV. 
0x01 = 2725 mV. 
… 
0x0B = 2975 mV. 
0x0C = 3000 mV. 
0x0D-0x3F = Reserved (2700 mV). 
0x40 = 3600 mV. 
0x41 = 3625 mV. 
… 
0x4F = 3975 mV. 
0x50 = 4000 mV. 
0x51-0x7F = Reserved (2700 mV). 
0x80 = 4175 mV. 
0x81 = 4200 mV. 
… 
0xA4 = 5075 mV. 
0xA5 = 5100 mV. 
0xA6-0xFF = Reserved (2700 mV)</L-4>
                              </DESC>
                            </ECUC-INTEGER-PARAM-DEF>
                            <ECUC-INTEGER-PARAM-DEF>
                              <SHORT-NAME>UV_ThresholdConfig</SHORT-NAME>
                              <DEFAULT-VALUE>0</DEFAULT-VALUE>
                              <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                              <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-POST-BUILD</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <MAX>50</MAX>
                              <MIN>0</MIN>
                              <DESC>
                                <L-4 L="EN">undervoltage threshold for the undervoltage protection.
0x00 = 1200 mV. 
0x01 = 1250 mV. 
… 
0x31 = 3650 mV. 
0x32 = 3700 mV.</L-4>
                              </DESC>
                            </ECUC-INTEGER-PARAM-DEF>
                          </PARAMETERS>
                        </ECUC-PARAM-CONF-CONTAINER-DEF>
                        <ECUC-PARAM-CONF-CONTAINER-DEF>
                          <SHORT-NAME>OTUT_Thresholds</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN"></L-2>
                          </DESC>
                          <LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
                          <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                          <MULTIPLICITY-CONFIG-CLASSES>
                            <ECUC-MULTIPLICITY-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-POST-BUILD</CONFIG-VARIANT>
                            </ECUC-MULTIPLICITY-CONFIGURATION-CLASS>
                            <ECUC-MULTIPLICITY-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-MULTIPLICITY-CONFIGURATION-CLASS>
                          </MULTIPLICITY-CONFIG-CLASSES>
                          <PARAMETERS>
                            <ECUC-INTEGER-PARAM-DEF>
                              <SHORT-NAME>UT1_ThresholdConfig</SHORT-NAME>
                              <DEFAULT-VALUE>0</DEFAULT-VALUE>
                              <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                              <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-POST-BUILD</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <MAX>7</MAX>
                              <MIN>0</MIN>
                              <DESC>
                                <L-4 L="EN">UT threshold for the under-temperature protection.
The PTC or NTC ranges are selected by the DEV_CONF2[PTC_EN] register. 
[PTC_EN] = 0: 
0b000-0b111 = Range from 72% to 86% of VTS in step of 2% (NTC). 
[PTC_EN] = 1: 
0b000-0b011 = Range from 43% to 46% of VTS in step of 1% (PTC). 
0b100-0b111 = Reserved (46%) (PTC).</L-4>
                              </DESC>
                            </ECUC-INTEGER-PARAM-DEF>
                            <ECUC-INTEGER-PARAM-DEF>
                              <SHORT-NAME>OT1_ThresholdConfig</SHORT-NAME>
                              <DEFAULT-VALUE>0</DEFAULT-VALUE>
                              <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                              <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-POST-BUILD</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <MAX>15</MAX>
                              <MIN>0</MIN>
                              <DESC>
                                <L-4 L="EN">the OT threshold for the overtemperature protection .
The PTC or NTC ranges are selected by the DEV_CONF2[PTC_EN] register. 
[PTC_EN] = 0: 
0b0_0000-0b1_0100 = Range from 10% to 30% of VTS in step of 1% (NTC). 
0b1_0101-0b1_1111 = Reserved (30%) (NTC). 
[PTC_EN] = 1: 
0b0_0000-0b0_0111 = Range from 53% to 60% of VTS in step of 1% (PTC). 
0b0_1000-0b1_1111 = Reserved (60%) (PTC).</L-4>
                              </DESC>
                            </ECUC-INTEGER-PARAM-DEF>
                            <ECUC-INTEGER-PARAM-DEF>
                              <SHORT-NAME>UT2_ThresholdConfig</SHORT-NAME>
                              <DEFAULT-VALUE>0</DEFAULT-VALUE>
                              <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                              <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-POST-BUILD</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <MAX>7</MAX>
                              <MIN>0</MIN>
                              <DESC>
                                <L-4 L="EN">the UT threshold for the under-temperature protection.
The PTC or NTC ranges are selected by the DEV_CONF2[PTC_EN] register. 
[PTC_EN] = 0: 
0b000-0b111 = Range from 72% to 86% of VTS in step of 2% (NTC). 
[PTC_EN] = 1: 
0b000-0b011 = Range from 43% to 46% of VTS in step of 1% (PTC). 
0b100-0b111 = Reserved (46%) (PTC).</L-4>
                              </DESC>
                            </ECUC-INTEGER-PARAM-DEF>
                            <ECUC-INTEGER-PARAM-DEF>
                              <SHORT-NAME>OT2_ThresholdConfig</SHORT-NAME>
                              <DEFAULT-VALUE>0</DEFAULT-VALUE>
                              <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                              <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-POST-BUILD</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <MAX>15</MAX>
                              <MIN>0</MIN>
                              <DESC>
                                <L-4 L="EN">the OT threshold for the overtemperature protection .
The PTC or NTC ranges are selected by the DEV_CONF2[PTC_EN] register. 
[PTC_EN] = 0: 
0b0_0000-0b1_0100 = Range from 10% to 30% of VTS in step of 1% (NTC). 
0b1_0101-0b1_1111 = Reserved (30%) (NTC). 
[PTC_EN] = 1: 
0b0_0000-0b0_0111 = Range from 53% to 60% of VTS in step of 1% (PTC). 
0b0_1000-0b1_1111 = Reserved (60%) (PTC).</L-4>
                              </DESC>
                            </ECUC-INTEGER-PARAM-DEF>
                          </PARAMETERS>
