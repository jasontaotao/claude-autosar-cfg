<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_4-2-2.xsd">
  <!-- Top-level comment -->
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>Cluster</SHORT-NAME>
      <!-- Inner comment 1 -->
      <ELEMENTS>
        <ECUC-MODULE-CONFIGURATION-VALUES>
          <SHORT-NAME>TestModule</SHORT-NAME>
          <DEFINITION-REF DEST="ECUC-MODULE-DEF">/Test/TestModule</DEFINITION-REF>
          <CONTAINERS>
            <!-- Container comment -->
            <ECUC-CONTAINER-VALUE>
              <SHORT-NAME>TestContainer</SHORT-NAME>
              <PARAMETER-VALUES>
                <ECUC-NUMERICAL-PARAM-VALUE>
                  <DEFINITION-REF DEST="ECUC-INTEGER-PARAM-DEF">/Test/TestModule/TestParam</DEFINITION-REF>
                  <VALUE>42</VALUE>
                </ECUC-NUMERICAL-PARAM-VALUE>
              </PARAMETER-VALUES>
            </ECUC-CONTAINER-VALUE>
          </CONTAINERS>
        </ECUC-MODULE-CONFIGURATION-VALUES>
      </ELEMENTS>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>
