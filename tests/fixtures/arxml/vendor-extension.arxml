<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_4-2-2.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>EAS</SHORT-NAME>
      <ELEMENTS>
        <SERVICE-NEEDS>
          <NEEDED-HARDWARE-VARIANT>VARIANT-PRE-COMPILE</NEEDED-HARDWARE-VARIANT>
          <NEEDED-TRIGGER-MODE>EXTERNAL-TRIGGER</NEEDED-TRIGGER-MODE>
        </SERVICE-NEEDS>
        <EXCLUSIVE-AREA>
          <SHORT-NAME>DetExclusiveArea0</SHORT-NAME>
        </EXCLUSIVE-AREA>
        <EAS-CUSTOM-DATA>
          <RUNTIME-MODE>SUPERVISOR</RUNTIME-MODE>
          <CALLBACK>DetCallback</CALLBACK>
        </EAS-CUSTOM-DATA>
        <ECUC-MODULE-CONFIGURATION-VALUES>
          <SHORT-NAME>Det</SHORT-NAME>
          <DEFINITION-REF DEST="ECUC-MODULE-DEF">/EAS/Det</DEFINITION-REF>
          <CONTAINERS>
            <ECUC-CONTAINER-VALUE>
              <SHORT-NAME>DetGeneral</SHORT-NAME>
              <DEFINITION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/EAS/Det/DetGeneral</DEFINITION-REF>
              <PARAMETER-VALUES>
                <ECUC-NUMERICAL-PARAM-VALUE>
                  <DEFINITION-REF DEST="ECUC-BOOLEAN-PARAM-DEF">/EAS/Det/DetGeneral/DetDebugLoop</DEFINITION-REF>
                  <VALUE>false</VALUE>
                </ECUC-NUMERICAL-PARAM-VALUE>
              </PARAMETER-VALUES>
            </ECUC-CONTAINER-VALUE>
          </CONTAINERS>
        </ECUC-MODULE-CONFIGURATION-VALUES>
      </ELEMENTS>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>